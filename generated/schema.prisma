model Verification {
  id        String   @id @default(uuid())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  otpCode   String // Diganti dari token menjadi otp_code
  expiresAt DateTime // Batas waktu OTP valid
  createdAt DateTime @default(now())

  // Mencegah ada otp_code dan email yang sama persis ganda di database
  @@unique([user_id, otpCode])
  @@map("verifications")
}

model Assignment {
  id String @id @default(uuid())

  class_id String
  class    Class  @relation(fields: [class_id], references: [id], onDelete: Cascade)

  mentor_id String
  mentor    User   @relation("MentorAssignments", fields: [mentor_id], references: [id])

  title           String
  description     String?        @db.Text
  submission_type SubmissionType
  attachment_url  String? // Link soal (opsional)
  due_date        DateTime

  created_at DateTime @default(now())

  submissions AssignmentContent[]

  @@map("assignments")
}

model AssignmentContent {
  id String @id @default(uuid())

  assignment_id String
  assignment    Assignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)

  santri_id String
  santri    User   @relation("SantriSubmissions", fields: [santri_id], references: [id], onDelete: Cascade)

  content_type    ContentType
  file_url        String[]
  score           Int?
  mentor_feedback String?       @db.Text
  status          GradingStatus @default(PENDING)

  submitted_at DateTime @default(now())

  @@unique([assignment_id, santri_id])
  @@map("assignment_content")
}

model Attendance {
  id String @id @default(uuid())

  class_id String
  class    Class  @relation(fields: [class_id], references: [id], onDelete: Cascade)

  santri_id String
  santri    User   @relation("SantriAttendances", fields: [santri_id], references: [id], onDelete: Cascade)

  mentor_id String
  mentor    User   @relation("MentorAttendances", fields: [mentor_id], references: [id])

  date      DateTime         @db.Date
  status    AttendanceStatus
  notes     String?          @db.Text
  image_url String? // Bukti kehadiran/sakit/izin

  created_at DateTime @default(now())

  // Memastikan 1 santri hanya diabsen 1 kali per kelas per hari
  @@unique([class_id, santri_id, date])
  @@map("attendances")
}

model Class {
  id          String   @id @default(uuid())
  division_id String
  division    Division @relation(fields: [division_id], references: [id], onDelete: Restrict)

  name String

  mentor_id String
  mentor    User   @relation("MentorClasses", fields: [mentor_id], references: [id])

  created_at DateTime @default(now())

  attendances     Attendance[]
  assignments     Assignment[]
  santri_profiles SantriProfile[]

  @@map("classes")
}

model Division {
  id          String   @id @default(uuid())
  name        String // Misal: SD, SMP, SMA, Tahfidz
  description String?  @db.Text
  created_at  DateTime @default(now())

  classes Class[]

  @@map("divisions")
}

model SantriProfile {
  id      String @id @default(uuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  nis        String    @unique
  birth_date DateTime? @db.Date
  address    String?   @db.Text
  photo_url  String?

  class_id String?
  class    Class?  @relation(fields: [class_id], references: [id], onDelete: SetNull)

  @@map("santri_profiles")
}

model User {
  id         String   @id @default(uuid())
  full_name  String
  email      String   @unique
  password   String
  phone      String? // Dibuat opsional (bisa null) karena mungkin tidak semua punya HP
  role       Role
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  // Relasi (Ini otomatis dibuat oleh Prisma untuk back-reference)
  verifications      Verification[]
  santri_profile     SantriProfile?
  mentor_classes     Class[]             @relation("MentorClasses")
  mentor_attendances Attendance[]        @relation("MentorAttendances")
  santri_attendances Attendance[]        @relation("SantriAttendances")
  mentor_assignments Assignment[]        @relation("MentorAssignments")
  santri_submissions AssignmentContent[] @relation("SantriSubmissions")

  // Relasi Wali Santri
  wali_relations   WaliSantriRelation[] @relation("WaliToRelation")
  santri_relations WaliSantriRelation[] @relation("SantriToRelation")

  @@map("users")
}

// Tabel Pivot Wali Santri
model WaliSantriRelation {
  id String @id @default(uuid())

  wali_id String
  wali    User   @relation("WaliToRelation", fields: [wali_id], references: [id], onDelete: Cascade)

  santri_id String
  santri    User   @relation("SantriToRelation", fields: [santri_id], references: [id], onDelete: Cascade)

  category WaliSantriCategory @default(OTHER)

  // Memastikan satu kombinasi wali dan anak tidak duplikat
  @@unique([wali_id, santri_id])
  @@map("wali_santri_relations")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../../generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MENTOR
  SANTRI
  WALI_SANTRI
}

enum AttendanceStatus {
  HADIR
  SAKIT
  IZIN
  ALFA
}

enum SubmissionType {
  TEXT
  FILE
}

enum GradingStatus {
  PENDING
  GRADED
}

enum ContentType {
  VIDEO
  FOTO
  TEXT
}

enum WaliSantriCategory {
  AYAH
  IBU
  OTHER
}
